# Loomo Configuration (Web + Extension)

# ===========================================
# WEB APPLICATION CONFIGURATION
# ===========================================

# Database (PostgreSQL local)
DATABASE_URL="postgresql://postgres:admin123@127.0.0.1:5432/loomo_db?schema=public"

# Google OAuth (dari Google Cloud Console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:8999"

# Security (generate pakai openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-key"
ENCRYPTION_KEY="your-32-byte-encryption-key" # 32 bytes hex
CRON_SECRET="your-cron-secret-hex"

# Storage
DEFAULT_SAVE_TO_OWNER_DRIVE=true

# ===========================================
# CHROME EXTENSION CONFIGURATION
# ===========================================

# Extension API Base URL (sama dengan NEXT_PUBLIC_APP_URL)
EXT_API_BASE_URL="http://localhost:8999"

# Recording Configuration (dalam menit)
EXT_MAX_RECORDING_MINUTES=4
EXT_WARNING_RECORDING_MINUTES=2

# Debug Mode (true/false)
EXT_DEBUG=true
