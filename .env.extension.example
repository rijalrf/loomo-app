# Loomo Extension Configuration

# API Base URL
# For local development: http://localhost:8999
# For production: https://your-domain.com
API_BASE_URL=http://localhost:8999

# Recording Configuration (in minutes)
# Maximum recording duration before auto-stop
MAX_RECORDING_MINUTES=4

# Show warning at this duration
WARNING_RECORDING_MINUTES=2

# Debug Mode (true/false)
# Set to false in production to disable all console logs
DEBUG=true
